# Copy to .env and customize (optional — all values have sensible defaults).
# Load before running: export $(grep -v '^#' .env | xargs)

# Where downloaded MP3s are stored (outside this repo)
SHOCKZ_LIBRARY_DIR=~/Music/shockz-library

# USB mount path when Shokz OpenSwim is connected (OpenSwim mounts as "SWIM PRO" on macOS)
SHOCKZ_DEVICE_PATH="/Volumes/SWIM PRO"

# Voice intro before each track (macOS `say` + ffmpeg). Set to false to disable globally.
SHOCKZ_ANNOUNCE=true

# macOS voice for spoken intros (run `say -v ?` to list voices)
SHOCKZ_ANNOUNCE_VOICE=Samantha

# Pause between spoken intro and music (seconds)
SHOCKZ_ANNOUNCE_PAUSE_SEC=0.35

# Default MP3 bitrate for downloads
SHOCKZ_DEFAULT_BITRATE=320

# Suggested max tracks in the active pool (headset only has forward/back)
SHOCKZ_RECOMMENDED_MAX_TRACKS=10

# Filename for the active-pool manifest inside the library directory
SHOCKZ_POOL_FILE=.on-device.txt
